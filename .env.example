# ─────────────────────────────────────────────────────────────────────────────
#  SETUP — one step:
#     1)  cp .env.example .env
#     2)  paste your OpenRouter API key below (free account, no credit card:
#         https://openrouter.ai/settings/keys)
#  Nothing else in this file needs to change to run the app.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM provider --------------------------------------------------------------
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-PASTE_YOUR_KEY_HERE        # ← the ONLY required change
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free

# --- AWS via LocalStack (leave as-is: AWS is EMULATED locally — no real AWS
# --- account or credentials are needed; these dummy values are correct) --------
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=repair-triage
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# --- schema-driven pipeline (paths inside the container) -----------------------
SCHEMA_PATH=schema/extraction_schema.json
SCHEMA_SPEC_PATH=schema/schema_spec.yaml
DATA_CSV_PATH=data/repair_notes_sample.csv

# --- LLM budget / throttle (OpenRouter free tier: ~20 req/min, 50 req/day) -----
MAX_REQUESTS_PER_MIN=20
MAX_REQUESTS_PER_DAY=50
RETRY_CAP=1

# --- OPTIONAL: swap the LLM provider by config only (not needed to run) --------
# Amazon Bedrock (real AWS) — set LLM_PROVIDER=bedrock and provide:
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0   # inference-profile id
# BEDROCK_AWS_REGION=us-east-1
# BEDROCK_AWS_ACCESS_KEY_ID=
# BEDROCK_AWS_SECRET_ACCESS_KEY=
# Self-hosted vLLM — set LLM_PROVIDER=vllm and point OPENROUTER_BASE_URL at your server.
