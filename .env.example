# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# --- LLM provider seam (Decision F) ---
LLM_PROVIDER=openrouter                       # openrouter | bedrock | vllm
OPENROUTER_API_KEY=sk-or-your-key-here        # required when LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free
# Phase 2 (Bedrock + Claude): set LLM_PROVIDER=bedrock and provide the model id + real AWS creds
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- AWS / LocalStack (endpoint from env → same code targets real AWS by dropping it) ---
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=repair-triage
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
# INGEST_QUEUE_URL=http://localhost:4566/000000000000/ingest   # Decision G (SQS)

# --- schema-driven pipeline ---
SCHEMA_PATH=schema/extraction_schema.json
SCHEMA_SPEC_PATH=schema/schema_spec.yaml

# --- budget / throttle (free tier: ~20/min, 50/day) ---
MAX_REQUESTS_PER_MIN=20
MAX_REQUESTS_PER_DAY=50
RETRY_CAP=1
WORKER_CONCURRENCY=4
